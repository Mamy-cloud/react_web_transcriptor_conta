{
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://conta-backend-fastapi.onrender.com/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "^.+\\.(js|css|png|jpg|jpeg|svg|ico|woff|woff2|ttf|map)$",
      "dest": "/$0"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
